generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("owner")
  permissions  Json?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSettings {
  id               String   @id @default(cuid())
  siteName         String
  tagline          String?
  phone            String?
  email            String?
  address          String?
  kvk              String?
  btw              String?
  website          String?
  linkedin         String?
  instagram        String?
  facebook         String?
  metaTitle        String?
  metaDescription  String?
  defaultOgImage   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PageSectionContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id              String   @id @default(cuid())
  slug            String   @unique
  sortOrder       Int      @default(0)
  nr              String?
  title           String
  subtitle        String?
  excerpt         String?
  checklist       Json?
  body            Json?
  imageUrl        String?
  seoTitle        String?
  seoDescription  String?
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Sector {
  id              String   @id @default(cuid())
  slug            String   @unique
  sortOrder       Int      @default(0)
  nr              String?
  name            String
  tagline         String?
  description     String?
  intro           String?
  items           Json?
  imageUrl        String?
  seoTitle        String?
  seoDescription  String?
  isPublished     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BlogPost {
  id              String   @id @default(cuid())
  slug            String   @unique
  sortOrder       Int      @default(0)
  title           String
  category        String?
  displayDate     String?
  publishedAt     DateTime?
  readTime        String?
  status          String   @default("Concept")
  featured        Boolean  @default(false)
  excerpt         String?
  body            Json?
  imageUrl        String?
  seoTitle        String?
  seoDescription  String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MediaAsset {
  id           String   @id @default(cuid())
  kind         String
  filename     String
  originalName String
  mimeType     String
  size         Int
  storagePath  String
  publicUrl    String
  altText      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leadSubmissions LeadSubmission[]
}

model LeadSubmission {
  id               String      @id @default(cuid())
  name             String
  company          String?
  email            String
  phone            String?
  message          String
  status           String      @default("new")
  attachmentId     String?
  attachment       MediaAsset? @relation(fields: [attachmentId], references: [id])
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
